generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  categories          Category[]
  budgetSeries        BudgetSeries[]
  IncomeSources       IncomeSource[]
  settings            UserSettings?
  categorizationRules CategorizationRule[]
  imports             Import[]
}

model Category {
  id        String   @id @default(cuid())
  label     String
  icon      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  budgetSeries        BudgetSeries[]
  categorizationRules CategorizationRule[]

  @@unique([userId, label])
  @@index([userId])
}

// The identity of a budget line across months. Name/icon/category/recurring are
// global (editing them affects every month); each month's numbers live on the
// SpendingItem "incarnation". Deleting the last incarnation leaves the series
// behind as dormant — resumable, never silently recreated.
model BudgetSeries {
  id         String   @id @default(cuid())
  name       String
  icon       String
  recurring  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  items      SpendingItem[]

  @@unique([userId, name])
  @@index([userId])
}

model SpendingItem {
  id        String   @id @default(cuid())
  month     String   // "YYYY-MM", zero-padded — identity + partition, never edited
  budgeted  Int      @default(0) // integer minor units (cents)
  spent     Int      @default(0) // integer minor units (cents); may be negative
  note      String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seriesId  String
  series    BudgetSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  spendingEntries SpendingEntry[]

  @@unique([seriesId, month])
  @@index([seriesId, month])
}

enum IncomeType {
  active
  passive
}

model IncomeSource {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  amount    Int      @default(0) // integer minor units (cents)
  icon      String
  type      IncomeType
  startDate DateTime @default(now())
  endDate   DateTime?
  note      String?  @db.VarChar(500)
  month     String
  bankRef   String?  // the source statement's own reference for the imported transaction (parser externalId)
  importId  String?
  import    Import?  @relation(fields: [importId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([userId, month])
}

enum Direction {
  debit
  credit
}

model SpendingEntry {
  id               String    @id             @default(cuid())
  name             String
  amount           Int       @default(0) // integer minor units (cents); always a positive magnitude — sign comes from direction
  direction        Direction @default(debit)
  receiptPath      String?   // Storage object key "<userId>/<entryId>" in the private `receipts` bucket
  receiptSizeBytes Int?      // authoritative object size, written only by the receipt confirm step; drives the 50 MB/user cap
  link             String?
  date             DateTime  @default(now())
  bankRef          String?   // the source statement's own reference for the imported transaction (parser externalId)
  importId         String?
  import           Import?   @relation(fields: [importId], references: [id], onDelete: SetNull)
  spendingItemId   String
  spendingItem     SpendingItem  @relation(fields: [spendingItemId], references: [id], onDelete: Cascade)
  @@index([spendingItemId])
}

model UserSettings {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency   String   @default("USD")
  dateFormat String   @default("MM/DD/YYYY")
  darkMode   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum RuleValueType {
  income
  spending
  exclude
}

// A learned categorization rule: case-insensitive substring key → destination
// (income / a spending category / exclusion). Several rows may share one match
// key — one row per destination, each carrying a use count. Confidence derives
// from row cardinality: exactly one row for a matching key → confident;
// several → suggested (highest count pre-filled). A deleted category cascades
// away its rules — consistent with the app's global-cascade semantics.
model CategorizationRule {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      String        // stored uppercase/trimmed; substring key
  valueType  RuleValueType
  categoryId String?       // required iff valueType == spending
  category   Category?     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  useCount   Int           @default(1)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([userId, match, valueType, categoryId])
  @@index([userId, match])
}

// One executed statement import — provenance for the entries it wrote (D21).
// Deleting an Import detaches its entries (SetNull) rather than deleting them;
// rollback is a future explicit feature, never a cascade.
model Import {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedAt     DateTime @default(now())
  filename       String?
  statementStart String?  // "YYYY-MM-DD" — the statement's opening-balance date when present (the parser exposes no explicit period)
  statementEnd   String?  // "YYYY-MM-DD" — the statement's closing-balance date when present
  totalCount     Int      // transactions in the file
  importedCount  Int      // routed entries written
  excludedCount  Int

  spendingEntries SpendingEntry[]
  incomeSources   IncomeSource[]
}