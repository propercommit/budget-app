generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  categories    Category[]
  spendingItems SpendingItem[]
  monthlyIncomes MonthlyIncome[]
}

model Category {
  id        String   @id @default(cuid())
  label     String
  icon      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  spendingItems SpendingItem[]
  
  @@unique([userId, label])
}

model SpendingItem {
  id        String   @id @default(cuid())
  name      String
  icon      String
  budgeted  Float    @default(0)
  spent     Float    @default(0)
  month     String   // Format: "2025-01"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  spendingEntries SpendingEntry[]
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@unique([userId, name, month])
}

model MonthlyIncome {
  id        String   @id @default(cuid())
  month     String   // Format: "2025-01"
  active    Float    @default(0)
  passive   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, month])
}

model SpendingEntry {
  id              String    @id             @default(cuid())
  name            String
  amount          Float     @default(0)
  receiptUrl      String?
  link            String?
  date            DateTime  @default(now())
  spendingItemId  String
  spendingItem    SpendingItem  @relation(fields: [spendingItemId], references: [id], onDelete: Cascade)
}